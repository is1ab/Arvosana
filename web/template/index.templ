package template

templ Base(children templ.Component) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<link href="/static/styles.css" rel="stylesheet"/>
			<title>Document</title>
		</head>
		<body>
			@children
		</body>
	</html>
}
